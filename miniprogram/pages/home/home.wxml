<navigation-bar title="" back="{{false}}" color="white" background="transparent"></navigation-bar>
<scroll-view class="page-scroll" scroll-y type="list">
  <view class="home-page">
    <view class="hero-section">
      <view class="hero-top">
        <view>
          <text class="hero-greeting">欢迎回来，{{nickname}}</text>
          <text class="hero-desc">E-Charge 为你汇聚附近优质站点、快捷充电入口与账户服务。</text>
        </view>
        <view class="hero-badge">车主服务</view>
      </view>

      <view class="balance-card">
        <view>
          <text class="balance-label">账户余额</text>
          <text class="balance-amount">￥{{balance}}</text>
        </view>
        <view class="balance-side">
          <text class="balance-side-title">当前优惠</text>
          <text class="balance-side-text">夜间服务费低至 8 折</text>
        </view>
      </view>
    </view>

    <view class="section-card">
      <view class="section-header">
        <text class="section-title">聚合服务</text>
        <text class="section-more">常用入口</text>
      </view>

      <view class="quick-grid">
        <view class="quick-item" wx:for="{{quickActions}}" wx:key="id" data-type="{{item.type}}" bindtap="onActionTap">
          <view class="quick-icon">{{item.icon}}</view>
          <text class="quick-title">{{item.title}}</text>
          <text class="quick-desc">{{item.desc}}</text>
        </view>
      </view>
    </view>

    <view class="section-card">
      <view class="section-header">
        <text class="section-title">推荐电站</text>
        <text class="section-more">优选站点</text>
      </view>

      <view class="station-card" wx:for="{{stations}}" wx:key="id" data-id="{{item.id}}" bindtap="onStationTap">
        <view class="station-main">
          <view class="station-topline">
            <text class="station-name">{{item.name}}</text>
            <text class="station-status">{{item.statusText}}</text>
          </view>
          <text class="station-address">{{item.address}}</text>
          <view class="station-meta">
            <text>{{item.operator}}</text>
            <text>{{item.distance}}</text>
            <text>{{item.available}} / {{item.total}} 空闲</text>
          </view>
        </view>
      </view>
    </view>

    <view class="section-card">
      <view class="section-header">
        <text class="section-title">优惠活动</text>
        <text class="section-more">精选福利</text>
      </view>

      <view class="promo-card" wx:for="{{promotions}}" wx:key="id" bindtap="onPromotionTap">
        <view class="promo-tag">{{item.tag}}</view>
        <view class="promo-content">
          <text class="promo-title">{{item.title}}</text>
          <text class="promo-desc">{{item.desc}}</text>
        </view>
      </view>
    </view>
  </view>
</scroll-view>
<custom-tab-bar />
