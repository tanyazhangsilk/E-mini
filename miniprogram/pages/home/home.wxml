<navigation-bar title="" back="{{false}}" color="white" background="transparent"></navigation-bar>
<scroll-view class="scrollarea" scroll-y type="list">
  <view class="home-page">
    <view class="header">
      <view class="header-top">
        <text class="greeting">Hi, {{nickname}}</text>
        <view class="settings-icon" bindtap="goSettings">▣</view>
      </view>
      <view class="quick-actions">
        <view class="action-item" bindtap="goScan">
          <view class="action-icon">⚡</view>
          <text class="action-text">扫码充电</text>
        </view>
        <view class="action-item" bindtap="goStations">
          <view class="action-icon">📍</view>
          <text class="action-text">附近电站</text>
        </view>
        <view class="action-item" bindtap="goWallet">
          <view class="action-icon">👛</view>
          <text class="action-text">我的钱包</text>
        </view>
      </view>
    </view>

    <view class="wallet-section">
      <view class="wallet-info">
        <text class="wallet-label">钱包余额</text>
        <text class="wallet-amount">¥{{balance}}</text>
      </view>
      <view class="recharge-btn" bindtap="goWallet">充值</view>
    </view>

    <view class="stations-section">
      <view class="section-header">
        <text class="section-title">精选充电站</text>
        <text class="view-all" bindtap="goStations">查看全部</text>
      </view>
      <view class="station-list">
        <view class="station-card" wx:for="{{stations}}" wx:key="id" bindtap="onStationTap" data-id="{{item.id}}">
          <view class="station-icon {{item.available / item.total >= 0.5 ? 'high' : 'low'}}">⚡</view>
          <view class="station-info">
            <text class="station-name">{{item.name}}</text>
            <text class="station-address">📍 {{item.address}}</text>
            <text class="station-operator">{{item.operator}}</text>
          </view>
          <text class="station-available {{item.available / item.total >= 0.5 ? 'high' : 'low'}}">{{item.available}}/{{item.total}}空闲</text>
        </view>
      </view>
    </view>
  </view>
</scroll-view>
<custom-tab-bar />
