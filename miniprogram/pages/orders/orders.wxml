<navigation-bar title="订单管理" back="{{true}}" color="black" background="#fff"></navigation-bar>
<view class="orders-page">
  <view class="empty-state" wx:if="{{orders.length === 0}}">
    <text class="empty-text">暂无订单</text>
  </view>
  <view class="order-list" wx:else>
    <view class="order-item" wx:for="{{orders}}" wx:key="id">
      <view class="order-header">
        <text class="order-no">订单号: {{item.orderNo}}</text>
        <text class="order-status">{{item.status}}</text>
      </view>
      <view class="order-detail">
        <text>{{item.stationName}}</text>
        <text>金额: ¥{{item.amount}}</text>
      </view>
      <text class="order-time">{{item.time}}</text>
    </view>
  </view>
</view>
