<navigation-bar title="我的订单" back="{{true}}" color="black" background="#f4f8fb"></navigation-bar>
<view class="orders-page">
  <view class="tabs-card">
    <view
      class="tab-item {{currentTab === item.key ? 'active' : ''}}"
      wx:for="{{tabs}}"
      wx:key="key"
      data-key="{{item.key}}"
      bindtap="switchTab"
    >
      {{item.label}}
    </view>
  </view>

  <view class="order-card" wx:for="{{displayOrders}}" wx:key="id" data-id="{{item.id}}" data-status="{{item.status}}" bindtap="onOrderTap">
    <view class="order-header">
      <view>
        <text class="order-name">{{item.stationName}}</text>
        <text class="order-time">{{item.startTime}}</text>
      </view>
      <text class="order-status {{item.status}}">{{item.statusText}}</text>
    </view>

    <view class="order-meta">
      <text>订单号 {{item.orderNo}}</text>
      <text>{{item.pileNo}} · {{item.gunNo}}</text>
    </view>

    <view class="order-summary">
      <view class="summary-item">
        <text class="summary-label">电量</text>
        <text class="summary-value">{{item.powerText}}</text>
      </view>
      <view class="summary-item">
        <text class="summary-label">金额</text>
        <text class="summary-value">￥{{item.amountText}}</text>
      </view>
      <view class="summary-item">
        <text class="summary-label">时长</text>
        <text class="summary-value">{{item.durationText}}</text>
      </view>
    </view>

    <view class="order-actions" wx:if="{{item.status === 'completed'}}">
      <view class="order-action-btn" catchtap="applyInvoice" data-id="{{item.id}}">申请发票</view>
      <view class="order-action-link">查看详情</view>
    </view>
  </view>
</view>
