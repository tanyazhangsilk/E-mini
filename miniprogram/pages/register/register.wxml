<navigation-bar title="用户注册" back="{{true}}" color="black" background="transparent"></navigation-bar>
<view class="auth-page">
  <view class="hero-card">
    <text class="hero-title">创建用户账号</text>
    <text class="hero-desc">填写基础信息后即可登录平台，使用找站充电、钱包支付与订单服务。</text>
  </view>

  <view class="form-card">
    <view class="field">
      <text class="field-label">用户昵称</text>
      <input class="field-input" placeholder="请输入昵称" value="{{nickname}}" bindinput="onNicknameInput" />
    </view>

    <view class="field">
      <text class="field-label">手机号 / 邮箱</text>
      <input class="field-input" placeholder="请输入手机号或邮箱" value="{{account}}" bindinput="onAccountInput" />
    </view>

    <view class="field">
      <text class="field-label">登录密码</text>
      <input class="field-input" password placeholder="请输入密码" value="{{password}}" bindinput="onPasswordInput" />
    </view>

    <view class="field">
      <text class="field-label">确认密码</text>
      <input
        class="field-input"
        password
        placeholder="请再次输入密码"
        value="{{confirmPassword}}"
        bindinput="onConfirmPasswordInput"
      />
    </view>

    <button class="primary-btn" bindtap="onRegister">注册账号</button>

    <view class="footer-line">
      <text class="footer-text">已有账号？</text>
      <text class="footer-link" bindtap="goLogin">返回登录</text>
    </view>
  </view>
</view>
