<navigation-bar title="" back="{{false}}" color="white" background="transparent"></navigation-bar>
<scroll-view class="wallet-scroll" scroll-y type="list">
  <view class="wallet-page">
    <view class="balance-card">
      <text class="balance-title">我的钱包</text>
      <text class="balance-subtitle">支持充值、消费展示与交易记录截图</text>
      <text class="balance-amount">￥{{balance}}</text>
      <view class="button-row">
        <view class="action-btn primary" bindtap="onRecharge">充值</view>
        <view class="action-btn secondary" bindtap="onRefresh">刷新</view>
      </view>
    </view>

    <view class="record-card">
      <view class="section-header">
        <text class="section-title">交易记录</text>
        <text class="section-more">{{records.length}} 条演示数据</text>
      </view>

      <view class="record-item" wx:for="{{records}}" wx:key="id">
        <view class="record-left">
          <text class="record-title">{{item.title}}</text>
          <text class="record-time">{{item.time}} · {{item.channel}}</text>
        </view>
        <text class="record-amount {{item.type}}">{{item.amountText}}</text>
      </view>
    </view>
  </view>
</scroll-view>
<custom-tab-bar />
