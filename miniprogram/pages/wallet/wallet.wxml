<navigation-bar title="" back="{{false}}" color="white" background="transparent"></navigation-bar>
<view class="wallet-page">
  <view class="balance-section">
    <text class="section-title">我的钱包</text>
    <text class="balance-label">账户余额 (元)</text>
    <text class="balance-amount">¥{{balance}}</text>
    <view class="action-btns">
      <view class="btn-recharge" bindtap="onRecharge">
        <text class="btn-icon">+</text>
        <text>充值</text>
      </view>
      <view class="btn-refresh" bindtap="onRefresh">
        <text class="btn-icon">↻</text>
        <text>刷新</text>
      </view>
    </view>
  </view>

  <view class="records-section">
    <text class="records-title">交易记录</text>
    <view class="empty-state" wx:if="{{records.length === 0}}">
      <text>暂无交易记录</text>
    </view>
    <view class="record-list" wx:else>
      <view class="record-item" wx:for="{{records}}" wx:key="id">
        <view class="record-info">
          <text class="record-desc">{{item.desc}}</text>
          <text class="record-time">{{item.time}}</text>
        </view>
        <text class="record-amount {{item.type}}">{{item.amount}}</text>
      </view>
    </view>
  </view>
</view>
<custom-tab-bar />
