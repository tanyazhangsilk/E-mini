<navigation-bar title="" back="{{false}}" color="black" background="#f4f8fb"></navigation-bar>
<scroll-view class="profile-scroll" scroll-y type="list">
  <view class="profile-page">
    <view class="user-card">
      <view class="avatar">E</view>
      <view class="user-main">
        <text class="nickname">{{nickname}}</text>
        <text class="email">{{email}}</text>
      </view>
      <view class="badge">账户中心</view>
    </view>

    <view class="stats-card">
      <view class="stat-item">
        <text class="stat-value">{{orderCount}}</text>
        <text class="stat-label">订单数量</text>
      </view>
      <view class="stat-item">
        <text class="stat-value">{{invoiceCount}}</text>
        <text class="stat-label">发票记录</text>
      </view>
      <view class="stat-item">
        <text class="stat-value">{{coupons}}</text>
        <text class="stat-label">优惠券</text>
      </view>
    </view>

    <view class="menu-card">
      <view class="menu-item" bindtap="goOrders">
        <text class="menu-left">我的订单</text>
        <text class="menu-right">查看充电记录</text>
      </view>
      <view class="menu-item" bindtap="goInvoices">
        <text class="menu-left">发票记录</text>
        <text class="menu-right">查看开票状态</text>
      </view>
      <view class="menu-item" bindtap="showCoupons">
        <text class="menu-left">优惠活动 / 优惠券</text>
        <text class="menu-right">{{coupons}} 张可用</text>
      </view>
      <view class="menu-item" bindtap="goWallet">
        <text class="menu-left">钱包</text>
        <text class="menu-right">余额 ￥{{balance}}</text>
      </view>
      <view class="menu-item" bindtap="showAbout">
        <text class="menu-left">关于平台</text>
        <text class="menu-right">服务介绍</text>
      </view>
    </view>

    <button class="logout-btn" bindtap="onLogout">退出登录</button>
  </view>
</scroll-view>
<custom-tab-bar />
