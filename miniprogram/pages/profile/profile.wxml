<navigation-bar title="" back="{{false}}" color="black" background="#fff"></navigation-bar>
<view class="profile-page">
  <view class="user-section">
    <view class="avatar">👤</view>
    <view class="user-info">
      <text class="nickname">{{nickname}}</text>
      <text class="email">{{email}}</text>
    </view>
  </view>

  <view class="menu-section">
    <view class="menu-item" bindtap="goWallet">
      <view class="menu-left">
        <text class="menu-icon">👛</text>
        <text class="menu-text">钱包</text>
      </view>
      <view class="menu-right">
        <text class="balance">¥{{balance}}</text>
        <text class="arrow">›</text>
      </view>
    </view>
    <view class="menu-item" bindtap="goChargingRecords">
      <view class="menu-left">
        <text class="menu-icon">⚡</text>
        <text class="menu-text">充电记录</text>
      </view>
      <text class="arrow">›</text>
    </view>
    <view class="menu-item" bindtap="goOrders">
      <view class="menu-left">
        <text class="menu-icon">📋</text>
        <text class="menu-text">订单管理</text>
      </view>
      <text class="arrow">›</text>
    </view>
  </view>

  <view class="logout-section">
    <view class="logout-btn" bindtap="onLogout">退出登录</view>
  </view>
</view>
<custom-tab-bar />
