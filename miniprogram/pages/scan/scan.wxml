<navigation-bar title="扫码充电" back="{{false}}" color="white" background="transparent"></navigation-bar>
<view class="scan-page">
  <view class="hero-card">
    <text class="hero-title">扫码充电</text>
    <text class="hero-desc">支持扫码识别与手动输入桩号两种方式，快速进入充电服务。</text>
  </view>

  <view class="scan-card">
    <text class="card-title">扫码识别区</text>
    <view class="scan-board">
      <view class="scan-frame">
        <view class="scan-line"></view>
      </view>
      <text class="scan-note">当前推荐站点：{{stationName}}</text>
    </view>
    <button class="primary-btn" bindtap="onQuickScan">立即识别</button>
  </view>

  <view class="manual-card">
    <text class="card-title">手动输入桩号</text>
    <input
      class="pile-input"
      placeholder="请输入充电桩编号，例如 TF-02"
      value="{{pileNo}}"
      bindinput="onPileInput"
    />
    <view class="quick-pile-row">
      <text class="quick-label">常用桩号</text>
      <view class="quick-pill" wx:for="{{quickPiles}}" wx:key="*this" data-value="{{item}}" bindtap="fillQuickPile">
        {{item}}
      </view>
    </view>
    <button class="ghost-btn" bindtap="onSearchPile">确认并充电</button>
  </view>
</view>
<custom-tab-bar />
