<navigation-bar title="附近电站" back="{{false}}" color="black" background="#f4f8fb"></navigation-bar>
<view class="stations-page">
  <view class="search-card">
    <view class="search-box">
      <text class="search-icon">搜</text>
      <input
        class="search-input"
        placeholder="搜索电站名称、地址或运营商"
        value="{{keyword}}"
        bindinput="onSearchInput"
      />
      <text class="clear-text" wx:if="{{keyword}}" bindtap="clearKeyword">清空</text>
    </view>
    <view class="filter-btn {{onlyIdle ? 'active' : ''}}" bindtap="toggleFilter">
      {{onlyIdle ? '空闲优先已开启' : '筛选：空闲优先'}}
    </view>
  </view>

  <view class="result-tip">当前为你筛选到 {{displayStations.length}} 个可选站点</view>

  <scroll-view class="station-list" scroll-y type="list">
    <view class="station-card" wx:for="{{displayStations}}" wx:key="id" data-id="{{item.id}}" bindtap="onStationTap">
      <view class="station-top">
        <view class="station-title-wrap">
          <text class="station-name">{{item.name}}</text>
          <text class="station-address">{{item.address}}</text>
        </view>
        <text class="station-distance">{{item.distance}}</text>
      </view>

      <view class="station-tags">
        <text class="tag operator">{{item.operator}}</text>
        <text class="tag status">{{item.statusText}}</text>
        <text class="tag price">{{item.priceText}}</text>
      </view>

      <view class="station-bottom">
        <text class="station-idle">空闲桩 {{item.available}} / {{item.total}}</text>
        <text class="station-link">站点详情</text>
      </view>
    </view>
  </scroll-view>
</view>
<custom-tab-bar />
