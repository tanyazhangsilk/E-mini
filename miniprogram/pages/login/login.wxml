<navigation-bar title="" back="{{false}}" color="black" background="transparent"></navigation-bar>
<view class="auth-page">
  <view class="hero-card panel-card">
    <view class="logo-mark">
      <text class="logo-text">E</text>
    </view>
    <text class="brand-title">E-Charge 聚合充电平台</text>
    <text class="brand-subtitle">聚合附近优质电站，提供找站、充电、支付与发票服务</text>
    <view class="hero-points">
      <text class="hero-chip">找站便捷</text>
      <text class="hero-chip">充电高效</text>
      <text class="hero-chip">账户清晰</text>
    </view>
  </view>

  <view class="form-card panel-card">
    <view class="section-title">
      <text class="section-heading">欢迎登录</text>
      <text class="section-desc">登录后即可查看附近电站、订单记录、钱包余额与开票服务。</text>
    </view>

    <view class="switch-row">
      <view class="switch-item {{loginType === 'mobile' ? 'active' : ''}}" data-type="mobile" bindtap="switchLoginType">手机号登录</view>
      <view class="switch-item {{loginType === 'email' ? 'active' : ''}}" data-type="email" bindtap="switchLoginType">邮箱登录</view>
    </view>

    <view class="field">
      <text class="field-label">{{accountLabel}}</text>
      <input
        class="field-input"
        placeholder="{{accountPlaceholder}}"
        value="{{account}}"
        bindinput="onAccountInput"
      />
    </view>

    <view class="field">
      <text class="field-label">登录密码</text>
      <input
        class="field-input"
        password
        placeholder="请输入登录密码"
        value="{{password}}"
        bindinput="onPasswordInput"
      />
    </view>

    <view class="agreement-row" bindtap="toggleAgree">
      <view class="agreement-check {{agreeChecked ? 'checked' : ''}}">{{agreeChecked ? '✓' : ''}}</view>
      <text class="agreement-text">我已阅读并同意《用户服务协议》《隐私政策》</text>
    </view>

    <button class="btn-primary" bindtap="onLogin">登录</button>
    <button class="btn-secondary" bindtap="onQuickLogin">快速体验</button>

    <view class="footer-line">
      <text class="footer-text">还没有账号？</text>
      <text class="footer-link" bindtap="goRegister">立即注册</text>
    </view>
  </view>
</view>
