<navigation-bar title="钱包充值" back="{{true}}" color="black" background="#f4f8fb"></navigation-bar>
<view class="recharge-page">
  <view class="card">
    <text class="card-title">选择常用金额</text>
    <view class="amount-grid">
      <view
        class="amount-item {{selectedAmount === item ? 'active' : ''}}"
        wx:for="{{presetAmounts}}"
        wx:key="*this"
        data-amount="{{item}}"
        bindtap="selectAmount"
      >
        ￥{{item}}
      </view>
    </view>
  </view>

  <view class="card">
    <text class="card-title">自定义金额</text>
    <input class="amount-input" type="digit" placeholder="请输入充值金额" value="{{customAmount}}" bindinput="onCustomInput" />
  </view>

  <button class="primary-btn" bindtap="submitRecharge">确认充值</button>
</view>
