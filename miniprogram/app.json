        "selectedIconPath": "assets/icons/station-active.png"
      },
      {
        "pagePath": "pages/scan/scan",
        "text": "充电",
        "iconPath": "assets/icons/charge.png",
        "selectedIconPath": "assets/icons/charge-active.png"
      },
      {
        "pagePath": "pages/wallet/wallet",
        "text": "钱包",
        "iconPath": "assets/icons/wallet.png",
        "selectedIconPath": "assets/icons/wallet-active.png"
      },
      {
        "pagePath": "pages/profile/profile",
